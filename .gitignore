# Xcode
*.xcodeproj/
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
*.xcworkspace/
xcuserdata/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/*/Package.resolved

# macOS
.DS_Store
*.swp
*~

# IDE
.idea/
*.xcuserstate
buildServer.json

# Build artifacts
build/

# Override global gitignore: track project docs and Claude Code config
!CLAUDE.md
!docs/
!docs/plans/
!docs/tasks/
!.claude/
# Re-ignore local-only Claude Code settings and agents (hooks stay tracked)
.claude/settings.local.json
.claude/agents/

# SPM build artifacts (symlink variant used on iCloud Drive)
.build.nosync/

# Obsidian symlinks (point to vault, not tracked in git)
docs/plans 2
docs/tasks 2
